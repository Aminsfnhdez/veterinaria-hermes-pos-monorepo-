# =============================================================================
# Veterinaria Hermes POS — variables de entorno (ejemplo)
#
# Backend NestJS (Etapa 3): copiar como backend/.env desde la raíz del repo,
# o duplicar las claves necesarias allí (Nest carga backend/.env al ejecutar
# npm run start:dev desde backend/).
# En producción (Vercel, proyecto con root = backend/): definir las mismas
# claves en el dashboard (no subir .env al repositorio).
# =============================================================================

# Entorno de ejecución (p. ej. development | production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Base de datos — Clever Cloud (PostgreSQL)
# Cadena URI completa que proporciona Clever Cloud para el add-on PostgreSQL.
# Formato típico: postgresql://usuario:password@host:puerto/nombre_bd?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://usuario:password@host-de-clevercloud:5432/nombre_bd

# -----------------------------------------------------------------------------
# JWT (NestJS)
# -----------------------------------------------------------------------------
JWT_SECRET=cambia_este_valor_en_produccion
JWT_EXPIRATION=8h

# -----------------------------------------------------------------------------
# Servidor API
# -----------------------------------------------------------------------------
PORT=3000
# Origen del frontend permitido para CORS
FRONTEND_URL=http://localhost:4200

# -----------------------------------------------------------------------------
# Seguridad — bcrypt
# Debe coincidir con rounds usados al hashear contraseñas (agent.md: 12).
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Facturación Colombia — establecimiento
# -----------------------------------------------------------------------------
COMPANY_NIT=900000000-0

# -----------------------------------------------------------------------------
# Frontend (Angular) — URL base del API
# Sustituir por la URL del backend en Vercel cuando exista.
# -----------------------------------------------------------------------------
# VITE_API_URL=https://tu-backend.vercel.app
